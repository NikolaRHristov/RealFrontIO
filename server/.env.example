# ==========================================
# REALFRONT GAME SERVER (NODE.JS / TYPESCRIPT)
# Path: /server/.env.example
# ==========================================
# This environment handles the core game loop, WebSocket
# connections with clients, and ingests the gRPC stream.

# 1. NETWORK CONFIGURATION
# Port for the WebSocket / HTTP Server
PORT=8080
WS_PORT=8081

# 2. CAPSULE COMMUNICATION
# The target address for the Rust Capsule's gRPC stream
CAPSULE_GRPC_URL=localhost:50051

# 3. GAME ENGINE TUNING
# Milliseconds per game tick (50ms = 20 TPS, 16ms = 60 TPS)
TICK_RATE_MS=50
# Maximum concurrent players per lobby
MAX_PLAYERS_PER_INSTANCE=100

# 4. SECRETS
# JWT Secret for player authentication (if implemented)
JWT_SECRET=super_secret_game_key_change_me

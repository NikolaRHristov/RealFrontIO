# ==========================================
# REALFRONT CLIENT (VITE / PIXI.JS / WEBGL)
# Path: /client/.env.example
# ==========================================
# NOTE: In Vite, only variables prefixed with VITE_ are 
# exposed to the browser. Do NOT put secret API keys here!

# 1. SERVER CONNECTIONS
# The WebSocket endpoint for the Node.js Game Server
VITE_WS_URL=ws://localhost:8081

# The REST endpoint for the Deep State Admin Console (Bypasses Node.js, hits Rust directly)
VITE_DEEP_STATE_API_URL=http://localhost:50052

# 2. RENDERER CONFIGURATION
# Set to 'true' to render collision meshes, A* paths, and 16-channel debug data
VITE_DEBUG_RENDER_MODE=false

# 3. ASSETS
# If deploying to a CDN (like AWS CloudFront), specify the base URL here
VITE_ASSET_CDN_URL=/assets/
# ==========================================
# RealFrontIO / WorldMonitor Master .env
# ==========================================
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Copy this to `.env` in the root directory
# ==========================================

# 1. CORE INFRASTRUCTURE
# Upstash or Local Redis for caching API responses (Critical for rate limits)
REDIS_URL=redis://default:YOUR_PASSWORD@your-upstash-url.upstash.io:30000

# 2. CONFLICT & GEOPOLITICS
# ACLED (Armed Conflict Location & Event Data Project) - Free for non-commercial
ACLED_EMAIL=your_email@domain.com
ACLED_API_KEY=your_acled_key

# 3. AVIATION & RECON
# OpenSky Network - Free tier (Requires auth to lift harsh rate limits)
OPENSKY_USERNAME=your_username
OPENSKY_PASSWORD=your_password

# 4. MARITIME LOGISTICS
# Spire / AIS Maritime Tracking - Paid API (Required for global shipping density)
# Alternative: FleetMon or MarineTraffic
SPIRE_AIS_TOKEN=your_spire_token

# 5. ECOLOGICAL & THERMAL
# NASA FIRMS (Fire Information for Resource Management System) - Free App Key required
NASA_FIRMS_MAP_KEY=your_nasa_firms_key

# 6. ECONOMIC & FINANCIAL
# Polymarket CLOB API - Free
POLYMARKET_API_KEY=your_poly_key
POLYMARKET_PASSPHRASE=your_poly_passphrase
POLYMARKET_SECRET=your_poly_secret

# NOTE: The following sources do NOT require API keys and are polled anonymously:
# - USGS Earthquakes (GeoJSON feed)
# - NOAA Space Weather / Wind Vectors
# - GDACS (Tsunamis/Floods RSS)
# - IAEA Nuclear Incident RSS
# ==========================================
# TURBOREPO ROOT ENVIRONMENT
# Path: /.env.example
# ==========================================
# Shared environment variables across the entire monorepo workspace.
# Used by Turborepo or Docker Compose to orchestrate the build.

# Deployment Environment (development, staging, production)
NODE_ENV=development

# Docker Compose Network Variables
COMPOSE_PROJECT_NAME=realfront_monorepo

# Monorepo Shared Ports (To prevent conflicts during local dev)
GLOBAL_VITE_PORT=3000
GLOBAL_WS_PORT=8081
GLOBAL_GRPC_PORT=50051
GLOBAL_REDIS_PORT=6379
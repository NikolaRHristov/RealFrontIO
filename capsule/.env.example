# ==========================================
# OPENFRONT CAPSULE (RUST MICROSERVICE)
# Path: /capsule/.env.example
# ==========================================
# This environment handles all heavy OSINT data scraping, 
# SQLite telemetry storage, and gRPC broadcasting.

# 1. NETWORK CONFIGURATION
GRPC_BIND_ADDR=0.0.0.0:50051
ADMIN_REST_ADDR=0.0.0.0:50052
LOG_LEVEL=info

# 2. DATASTORES
# Upstash or Local Redis for caching API responses (Critical for rate limits)
REDIS_URL=redis://127.0.0.1:6379
# SQLite local file for historical telemetry time-travel
DATABASE_URL=sqlite://telemetry.db

# 3. CONFLICT & GEOPOLITICS
# ACLED (Armed Conflict Location & Event Data Project)
ACLED_EMAIL=your_email@domain.com
ACLED_API_KEY=your_acled_key

# 4. AVIATION & RECON
# OpenSky Network - Free tier (Requires auth to lift harsh rate limits)
OPENSKY_USERNAME=your_username
OPENSKY_PASSWORD=your_password

# 5. MARITIME LOGISTICS
# Spire / AIS Maritime Tracking
SPIRE_AIS_TOKEN=your_spire_token

# 6. ECOLOGICAL & THERMAL
# NASA FIRMS (Fire Information for Resource Management System)
NASA_FIRMS_MAP_KEY=your_nasa_firms_key

# 7. ECONOMIC & FINANCIAL
# Polymarket CLOB API
POLYMARKET_API_KEY=your_poly_key
POLYMARKET_PASSPHRASE=your_poly_passphrase
POLYMARKET_SECRET=your_poly_secret